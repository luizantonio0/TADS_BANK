    {
      "id": "_X1omqbydl-CD7sTiM-1q",
      "type": "text",
      "x": 1247.244452582465,
      "y": 401.3888888888887,
      "width": 796.2333374023438,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "af",
      "roundness": null,
      "seed": 335815907,
      "version": 709,
      "versionNonce": 567441026,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1754504897244,
      "link": null,
      "locked": false,
      "text": "- Leaderboard:\nConfig guarda quando começou a ultima season\nPontos são acumulados junto com payouts\nPayout nao é necessariamente igual a quantidade de pontos\nSeason é finalizada manualmente por um administrador\nApós a season os pontos de todos os jogadores volta para 0\nO ranking é baseado apenas nos pontos do jogador\nAtualizado on-the-fly (nada em cache, usuário sempre recebe a versão atualizada)\nQtd. de pontos que cada atividade (weekly, graid, war e XP) dão é configurável\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Leaderboard:\nConfig guarda quando começou a ultima season\nPontos são acumulados junto com payouts\nPayout nao é necessariamente igual a quantidade de pontos\nSeason é finalizada manualmente por um administrador\nApós a season os pontos de todos os jogadores volta para 0\nO ranking é baseado apenas nos pontos do jogador\nAtualizado on-the-fly (nada em cache, usuário sempre recebe a versão atualizada)\nQtd. de pontos que cada atividade (weekly, graid, war e XP) dão é configurável\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
